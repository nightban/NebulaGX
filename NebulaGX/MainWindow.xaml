<Window x:Class="NebulaGX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Nebula GX"
        Width="1200" Height="700"
        Background="#0a0a0f"
        WindowStyle="None">

    <Grid>

        <!-- ЛЕВАЯ ПАНЕЛЬ -->
        <StackPanel Width="70" Background="#11111a" HorizontalAlignment="Left">
            <Button Content="🏠" Style="{StaticResource SideBtn}" Click="Home_Click"/>
            <Button Content="🔄" Style="{StaticResource SideBtn}" Click="Refresh_Click"/>
        </StackPanel>

        <!-- ВЕРХ -->
        <Grid Height="60" VerticalAlignment="Top" Background="#11111a" Margin="70,0,0,0">
            <TextBox Name="SearchBox"
                     Width="500"
                     Height="30"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     Background="#1a1a2e"
                     Foreground="White"
                     BorderBrush="#a020f0"
                     KeyDown="SearchBox_KeyDown"/>
        </Grid>

        <!-- ГЛАВНЫЙ БРАУЗЕР -->
        <wv2:WebView2 Name="Browser" Margin="70,60,0,0"/>

    </Grid>
</Window>
